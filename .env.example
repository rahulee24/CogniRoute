# LLM APIs
GEMINI_API_KEY=your_gemini_api_key
COHERE_API_KEY=your_cohere_api_key
TAVILY_API_KEY=your_tavily_api_key
PINECONE_API_KEY=your_pinecone_api_key

# Redis Configuration (Optional, fallback to in-memory dictionary is supported)
REDIS_URL=redis://localhost:6379

# Mock Mode Configuration
# Set to True to bypass external LLM/Retrieval API calls and run offline with mock behaviors
MOCK_MODE=True

# Database Configuration
SQLITE_DB_PATH=data/company_sales.db

# Retrieval Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5
MMR_LAMBDA=0.7

# Quality Guard Configuration
CONFIDENCE_THRESHOLD=0.7
MAX_REROUTES=2

# Session Memory Window (number of past turns)
MEMORY_WINDOW=5

# Generation Config
MAX_TOKENS=1024
STREAMING=True
